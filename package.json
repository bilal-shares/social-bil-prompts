    "functions:build": "wrangler pages functions build functions --outfile .wrangler/functions.js"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "next": "16.2.7",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260606.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "wrangler": "4.98.0"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
