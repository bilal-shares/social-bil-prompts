{
  "name": "social-bil-prompts",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run build && wrangler pages dev out --port 3000",
    "dev:ui": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "pages:dev": "npm run dev",
